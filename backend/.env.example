# Copy to .env and fill in real values.
# Generate a fresh JWT secret and encryption key for production!

# Project
PROJECT_NAME=ChatBot Platform
API_V1_PREFIX=/v1

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Encryption key for provider API keys (Fernet).
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-fernet-key

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=chatbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Initial admin
CREATE_ADMIN_ON_STARTUP=true
ADMIN_EMAIL=admin@chatbot.com
ADMIN_PASSWORD=Admin12345

# CORS ("*" lets the widget embed on any site)
CORS_ORIGINS=*

# Email
EMAIL_PROVIDER=smtp
SENDER_EMAIL=noreply@chatbot.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_REGION=eu-central-1
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false

# OTP / verification / reset / 2FA
OTP_LENGTH=6
OTP_EXPIRATION_MINUTES=10
EMAIL_VERIFICATION_TOKEN_EXPIRATION_MINUTES=60
REQUIRE_EMAIL_VERIFICATION=false
PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=60
FORCE_TWO_FACTOR_AUTH=false

# URLs
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Chatbot tuning
FEED_DATA_MAX_CHARS=20000
CHAT_HISTORY_LIMIT=20

# Celery / background jobs (sitemap feed generation). In docker-compose the app
# and worker get CELERY_BROKER_URL=redis://redis:6379/0 via the compose file.
CELERY_BROKER_URL=redis://localhost:6379/0
# Set true only to run tasks inline without a broker (e.g. tests).
CELERY_TASK_ALWAYS_EAGER=false

# Custom widget CSS/JS size caps
CUSTOM_CSS_MAX_CHARS=20000
CUSTOM_JS_MAX_CHARS=20000
